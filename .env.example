# Site
NEXT_PUBLIC_SITE_URL=https://yourname.dev
NEXT_PUBLIC_GITHUB_URL=https://github.com/yourusername
NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/in/yourprofile

# Calendly (set ENABLED to "true" when you have availability)
NEXT_PUBLIC_CALENDLY_ENABLED=false
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/yourname/30min

# Feature toggles (set to "true" to show)
NEXT_PUBLIC_SHOW_CV_DOWNLOAD=false
NEXT_PUBLIC_SHOW_SECURITY_SKILLS=false

# Contact form (server-only — never prefix with NEXT_PUBLIC_)
RESEND_API_KEY=re_xxxxxxxxxxxx
CONTACT_TO_EMAIL=you@yourdomain.com
CONTACT_FROM_EMAIL=noreply@yourname.dev
